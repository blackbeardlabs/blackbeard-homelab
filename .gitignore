# OS and editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# Local environment and secrets
.env
.env.*
!.env.example
*.pem
*.key

# Runtime artifacts
*.pid
*.tmp
*.temp
*.cache

# Logs
*.log
!raw-logs/*.log
